# Configuracoes de API (URL publica HTTPS da API — ex.: VPS com dominio proprio)
# Preferir NEXT_PUBLIC_API_BASE_URL; NEXT_PUBLIC_API_URL e um alias.
NEXT_PUBLIC_API_BASE_URL=https://api.seudominio.com
NEXT_PUBLIC_API_URL=https://api.seudominio.com
NEXT_PUBLIC_USE_HTTPS=true

# Catálogo público: opcional; se vazio, usa a mesma base acima (getApiBaseUrl).
# NEXT_PUBLIC_PUBLIC_API_URL=https://api.seudominio.com

# Configuracoes de Debug (opcional)
# NEXT_PUBLIC_DEBUG=false

# Configuracoes de Error Logging (opcional)
# NEXT_PUBLIC_ERROR_API_ENDPOINT=https://seu-endpoint.com/api/errors
